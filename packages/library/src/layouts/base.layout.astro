---
import { ViewTransitions } from "astro:transitions";

interface Props {
  title: string;
  seo: {
    description: string;
    title: string;
  };
  theme: {
    primary: string;
    primaryForeground: string;
  };
  git: {
    repo: string;
    user: string;
  };
}

const {
  title,
  seo,
  theme,
  git: { repo, user },
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={seo.description} />
    <meta name="robots" content="index, follow" />

    <link rel="canonical" href={import.meta.env.SITE + currentPath} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | {seo.title}</title>
    <ViewTransitions />
    <style
      define:vars={{
        primary: theme.primary,
        "primary-foreground": theme.primaryForeground,
      }}
    ></style>
    <script is:inline define:vars={{ repo, user }}>
      console.log(`=====================================================================
If you're here, you're clearly prepared to dive into the code! We're always 
striving to make this website better - and we'd love your help! 

🌍 Find the Source Code:
Our website's code is hosted on GitHub! You can explore, download, and contribute at:
📍 GitHub Repository: https://github.com/${repo}/${user}

🏆 How You Can Help:
1. 📝 Report an Issue: Spotted any bugs or things that need improvement? Open an issue and let us know.
2. 🔧 Contribute Code: Fork the repository, add your improvements, and submit a pull request.
3. 💡 Share Ideas: Every great adventure starts with a new idea. Join the discussion in our issues section!

🌠 Every bit of effort, big or small, helps us build a better digital Scouting experience for all.
=====================================================================`);
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
<link rel="icon" type="image/x-icon" href="/images/favicon.ico" />
